---
import Layout from '../layouts/Layout.astro';
import samples from '../../filter-samples.json';

const filters = [
  {
    key: 'sharpen',
    name: 'くっきり',
    description: 'コントラスト強調 + 明るさ微調整。一般的な文書をはっきり読みやすくする。',
    formula: 'contrast(1.4) * brightness(1.05)',
    detail: 'コントラストを 1.4 倍に引き上げ、明るさを 5% 上げることで、白い紙面と黒い文字の差を広げる。ColorMatrix のみで完結し、処理コストはほぼゼロ。',
  },
  {
    key: 'bw',
    name: '白黒',
    description: 'グレースケール化 + コントラスト強調。白黒コピーやFAX用途に最適。',
    formula: 'grayscale(1.0) * contrast(1.3)',
    detail: 'BT.601 の輝度係数 (R=0.2127, G=0.7151, B=0.0722) でグレースケールに変換し、コントラストを 1.3 倍で引き締める。色情報は完全に破棄される。',
  },
  {
    key: 'magic',
    name: 'マジック',
    description: 'OpenCV による比率正規化・照明補正・自動トーン伸長・紙面白化・色保持を組み合わせた決定的パイプライン。既定フィルタ。',
    formula: 'A4 ratio normalization → Flat-field correction → Auto RMODE → Paper whitening',
    detail: 'A4 に近い比率の文書は、画素数をほぼ維持したまま正確な A4 比率へ寄せる（Step 1）。その後、Lab 色空間の L チャンネルをぼかし面で割り戻して照明ムラを除去し（Step 2）、ヒストグラムの黒白点で自動ストレッチし、紙領域は白化しつつアクセント色を保持する（Step 3）。',
    steps: [
      { label: 'Step 1', description: 'A4比率補正: A4 に近い文書だけ、縦横をバランスよく伸縮して正確な紙比率へ寄せる。' },
      { label: 'Step 2', description: '照明ムラ補正: L_flat = L / blur(L) * mean(blur(L))' },
      { label: 'Step 3', description: '自動トーン + 白化: L_stretch = clamp((L_flat - blackPoint) / (whitePoint - blackPoint))' },
    ],
  },
  {
    key: 'whiteboard',
    name: 'ホワイトボード',
    description: '高明度 + 高コントラスト + 完全彩度除去。ホワイトボード撮影を白黒はっきりにする。',
    formula: 'brightness(1.3) * contrast(1.6) * saturate(0)',
    detail: '明るさ 1.3 倍とコントラスト 1.6 倍で背景を飛ばし、saturate(0) で完全モノクロ化。ホワイトボード上のマーカー線がくっきり読める状態にする。',
  },
  {
    key: 'vivid',
    name: '鮮やか',
    description: '彩度強調 + コントラスト微調整。カラー文書や図表の色を鮮やかにする。',
    formula: 'saturate(2.0) * contrast(1.2)',
    detail: '彩度を 2 倍に引き上げて色を強調し、コントラスト 1.2 倍で軽く引き締める。カラーの図表、ポスター、イラスト付き資料に効果的。',
  },
];

function buildViewerForFilter(filterKey, sample) {
  const steps = [
    { label: 'Step 0', src: '/' + sample.step0.replace('docs/public/', ''), caption: 'Step 0: 台形選択とクロップ後。' },
    { label: 'Step 1', src: '/' + sample.step1.replace('docs/public/', ''), caption: 'Step 1: A4 比率に近い文書だけ、画素数をほぼ維持したまま紙比率へ正規化。' },
  ];

  if (filterKey === 'magic') {
    steps.push(
      { label: 'Step 2', src: '/' + sample.magic_step2.replace('docs/public/', ''), caption: 'Step 2: 照明ムラ補正後。' },
      { label: 'Step 3', src: '/' + sample.magic_step3.replace('docs/public/', ''), caption: 'Step 3: 最終出力。Auto RMODE + 紙面白化。' },
    );
  } else {
    const filterPath = sample.filters[filterKey];
    steps.push(
      { label: 'フィルタ適用', src: '/' + filterPath.replace('docs/public/', ''), caption: `フィルタ適用後。` },
    );
  }

  return steps;
}
---

<Layout title="CamScanShare - フィルタ解説">
  <header class="algo-header">
    <div class="algo-header-inner">
      <div>
        <a href="/" class="algo-back">&larr; 画面設計ドキュメントへ戻る</a>
        <h1>フィルタ解説</h1>
        <p class="algo-subtitle">
          各フィルタの処理パラメータとサンプル画像を掲載する。
          ここでアルゴリズムを検証・研究し、確定したパラメータをアプリに移植する。
        </p>
      </div>
    </div>
  </header>

  <nav class="algo-nav" id="filterNav">
    <div class="algo-nav-inner">
      <a href="#perspective" class="filter-tab" data-filter-key="perspective">台形選択</a>
      {filters.map((f) => (
        <a href={`#filter-${f.key}`} class="filter-tab" data-filter-key={f.key}>{f.name}</a>
      ))}
    </div>
  </nav>

  <main class="algo-main">
    <section class="algo-section filter-section" id="perspective" data-filter-section="perspective">
      <div class="section-heading">
        <h2>台形選択</h2>
        <p>撮影画像から紙の四隅を検出し、射影変換で正面ビューにそろえる。A4 に近い比率の文書は、その後に紙比率へ正規化してからフィルタを適用する。</p>
      </div>

      <div class="example-stack">
        {samples.map((sample) => {
          const viewerId = `perspective-${sample.id}`;
          const viewer = [
            { label: 'オリジナル', src: '/' + sample.source.replace('docs/public/', ''), caption: 'オリジナル: カメラ撮影そのままの入力画像。' },
            { label: 'Step 0', src: '/' + sample.step0.replace('docs/public/', ''), caption: 'Step 0: 紙領域を検出し、正面に射影変換した状態。' },
            { label: 'Step 1', src: '/' + sample.step1.replace('docs/public/', ''), caption: 'Step 1: A4 に近い文書だけ、画素数をほぼ維持したまま紙比率へ正規化。' },
          ];
          return (
            <article class="sample-view-card">
              <p class="sample-title">{sample.title}</p>
              <figure class="case-figure sample-view-figure">
                <div class="step-viewer" data-viewer={viewerId}>
                  <div class="step-toggle-row">
                    {viewer.map((step, index) => (
                      <button
                        type="button"
                        class={`step-toggle${index === 0 ? ' is-active' : ''}`}
                        data-viewer-target={viewerId}
                        data-src={step.src}
                        data-caption={step.caption}
                      >
                        {step.label}
                      </button>
                    ))}
                  </div>
                  <img
                    class="step-viewer-image"
                    data-step-image={viewerId}
                    src={viewer[0].src}
                    alt={`${sample.title} - 台形選択`}
                    loading="lazy"
                  />
                  <div class="step-viewer-meta">
                    <p class="step-viewer-caption" data-step-caption={viewerId}>{viewer[0].caption}</p>
                  </div>
                </div>
              </figure>
            </article>
          );
        })}
      </div>
    </section>

    {filters.map((filter) => (
      <section class="algo-section filter-section" id={`filter-${filter.key}`} data-filter-section={filter.key}>
        <div class="section-heading">
          <h2>{filter.name}</h2>
          <p>{filter.description}</p>
        </div>

        <div class="filter-spec">
          <div class="spec-card">
            <h3>パラメータ</h3>
            <pre><code>{filter.formula}</code></pre>
            <p>{filter.detail}</p>
          </div>

          {filter.steps && (
            <div class="pipeline-list">
              {filter.steps.map((step, i) => (
                <article class="pipeline-step">
                  <div class="step-index">{i + 1}</div>
                  <div>
                    <h3>{step.label}</h3>
                    <p>{step.description}</p>
                  </div>
                </article>
              ))}
            </div>
          )}
        </div>

        <div class="section-heading" style="margin-top: var(--ds-space-400);">
          <h3>サンプル</h3>
        </div>

        <div class="example-stack">
          {samples.map((sample) => {
            const viewerId = `${filter.key}-${sample.id}`;
            const viewer = buildViewerForFilter(filter.key, sample);
            return (
              <article class="sample-view-card">
                <p class="sample-title">{sample.title}</p>
                <figure class="case-figure sample-view-figure">
                  <div class="step-viewer" data-viewer={viewerId}>
                    <div class="step-toggle-row">
                      {viewer.map((step, index) => (
                        <button
                          type="button"
                          class={`step-toggle${index === 0 ? ' is-active' : ''}`}
                          data-viewer-target={viewerId}
                          data-src={step.src}
                          data-caption={step.caption}
                        >
                          {step.label}
                        </button>
                      ))}
                    </div>
                    <img
                      class="step-viewer-image"
                      data-step-image={viewerId}
                      src={viewer[0].src}
                      alt={`${sample.title} - ${filter.name}`}
                      loading="lazy"
                    />
                    <div class="step-viewer-meta">
                      <p class="step-viewer-caption" data-step-caption={viewerId}>{viewer[0].caption}</p>
                    </div>
                  </div>
                </figure>
              </article>
            );
          })}
        </div>
      </section>
    ))}
  </main>
</Layout>

<style>
  .algo-header {
    background: linear-gradient(135deg, #0c66e4 0%, #1d7af0 55%, #7fd0ff 100%);
    color: var(--ds-text-inverse);
    padding: var(--ds-space-500) var(--ds-space-400);
  }

  .algo-header-inner,
  .algo-nav-inner,
  .algo-main {
    max-width: 1180px;
    margin: 0 auto;
  }

  .algo-back {
    display: inline-flex;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    font-size: var(--ds-font-size-100);
    margin-bottom: var(--ds-space-150);
  }

  .algo-back:hover { color: #fff; }

  .algo-header h1 {
    font-size: clamp(32px, 4vw, 54px);
    line-height: 1.05;
    margin-bottom: var(--ds-space-150);
  }

  .algo-subtitle {
    max-width: 760px;
    font-size: var(--ds-font-size-200);
    line-height: 1.8;
    opacity: 0.94;
  }

  .algo-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--ds-border);
  }

  .algo-nav-inner {
    display: flex;
    gap: 0;
    overflow-x: auto;
    padding: 0 var(--ds-space-400);
  }

  .algo-nav-inner::-webkit-scrollbar { display: none; }

  .filter-tab {
    display: inline-flex;
    align-items: center;
    padding: var(--ds-space-150) var(--ds-space-200);
    color: var(--ds-text-subtle);
    text-decoration: none;
    white-space: nowrap;
    font-weight: var(--ds-font-weight-medium);
    font-size: var(--ds-font-size-100);
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .filter-tab:hover { color: var(--ds-text-brand); }

  .filter-tab.is-active {
    color: var(--ds-text-brand);
    border-bottom-color: var(--ds-border-brand);
  }

  .algo-main {
    padding: var(--ds-space-500) var(--ds-space-400) var(--ds-space-800);
  }

  .algo-section + .algo-section {
    margin-top: var(--ds-space-800);
  }

  .section-heading {
    max-width: 820px;
    margin-bottom: var(--ds-space-400);
  }

  .section-heading h2 {
    font-size: clamp(24px, 3vw, 40px);
    line-height: 1.15;
    margin-bottom: var(--ds-space-150);
  }

  .section-heading h3 {
    font-size: clamp(20px, 2.5vw, 28px);
    line-height: 1.15;
    margin-bottom: var(--ds-space-100);
  }

  .section-heading p {
    color: var(--ds-text-subtle);
    font-size: var(--ds-font-size-200);
    line-height: 1.8;
  }

  .filter-spec {
    display: grid;
    gap: var(--ds-space-200);
    margin-bottom: var(--ds-space-300);
  }

  .spec-card {
    background: var(--ds-surface-raised);
    border: 1px solid var(--ds-border);
    border-radius: 18px;
    box-shadow: var(--ds-shadow-raised);
    padding: var(--ds-space-300);
  }

  .spec-card h3 {
    margin-bottom: var(--ds-space-100);
    font-size: var(--ds-font-size-300);
  }

  .spec-card pre {
    margin: var(--ds-space-150) 0;
    padding: var(--ds-space-200);
    border-radius: 14px;
    background: #101828;
    color: #e9f2ff;
    overflow-x: auto;
    font-size: 13px;
  }

  .spec-card p {
    color: var(--ds-text-subtle);
    line-height: 1.8;
  }

  .pipeline-list {
    display: grid;
    gap: var(--ds-space-150);
  }

  .pipeline-step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: var(--ds-space-200);
    padding: var(--ds-space-250, 20px);
    background: var(--ds-surface-raised);
    border: 1px solid var(--ds-border);
    border-radius: 18px;
    box-shadow: var(--ds-shadow-raised);
  }

  .step-index {
    width: 56px;
    height: 56px;
    border-radius: 18px;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #0c66e4, #7f56d9);
    color: white;
    font-size: 22px;
    font-weight: var(--ds-font-weight-bold);
  }

  .pipeline-step h3 { margin-bottom: var(--ds-space-100); }
  .pipeline-step p { color: var(--ds-text-subtle); line-height: 1.8; }

  .example-stack {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--ds-space-300);
    align-items: start;
  }

  .sample-view-card {
    display: grid;
    gap: var(--ds-space-100);
    align-self: start;
  }

  .sample-title {
    font-weight: var(--ds-font-weight-semibold);
    font-size: var(--ds-font-size-075);
    color: var(--ds-text-subtle);
  }

  .case-figure,
  .sample-view-figure {
    background: var(--ds-surface-raised);
    border: 1px solid var(--ds-border);
    border-radius: 20px;
    box-shadow: var(--ds-shadow-raised);
    overflow: hidden;
    position: static;
  }

  .case-figure img {
    display: block;
    width: 100%;
    height: auto;
    background: #fff;
  }

  .step-viewer {
    display: grid;
    gap: var(--ds-space-150);
    padding: var(--ds-space-200);
  }

  .step-toggle-row {
    display: flex;
    gap: var(--ds-space-100);
    flex-wrap: wrap;
  }

  .step-toggle {
    border: 1px solid var(--ds-border);
    background: var(--ds-surface);
    color: var(--ds-text-subtle);
    border-radius: 999px;
    padding: 8px 14px;
    font: inherit;
    font-weight: var(--ds-font-weight-semibold);
    cursor: pointer;
    transition: 0.18s ease;
  }

  .step-toggle:hover {
    border-color: var(--ds-border-brand);
    color: var(--ds-text-brand);
  }

  .step-toggle.is-active {
    background: #e9f2ff;
    border-color: var(--ds-border-brand);
    color: var(--ds-text-brand);
  }

  .step-viewer-image {
    width: 100%;
    display: block;
    border-radius: 16px;
    border: 1px solid var(--ds-border);
    background: #fff;
  }

  .step-viewer-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--ds-space-150);
  }

  .step-viewer-caption {
    color: var(--ds-text-subtle);
    font-size: var(--ds-font-size-075);
    line-height: 1.7;
  }

  @media (max-width: 960px) {
    .example-stack {
      grid-template-columns: 1fr;
    }

    .step-viewer-meta {
      align-items: flex-start;
      flex-direction: column;
    }

    .algo-main,
    .algo-nav-inner {
      padding-left: var(--ds-space-200);
      padding-right: var(--ds-space-200);
    }
  }
</style>

<script>
  // Step toggle (image viewer)
  document.querySelectorAll('.step-toggle').forEach((button) => {
    button.addEventListener('click', () => {
      const viewer = button.dataset.viewerTarget;
      const src = button.dataset.src;
      const caption = button.dataset.caption;
      if (!viewer || !src || !caption) return;

      const image = document.querySelector(`[data-step-image="${viewer}"]`);
      const captionNode = document.querySelector(`[data-step-caption="${viewer}"]`);
      if (!image || !captionNode) return;

      document
        .querySelectorAll(`.step-toggle[data-viewer-target="${viewer}"]`)
        .forEach((node) => node.classList.remove('is-active'));

      button.classList.add('is-active');
      image.setAttribute('src', src);
      captionNode.textContent = caption;
    });
  });

  // Scroll spy for filter tabs
  const filterSections = document.querySelectorAll('.filter-section');
  const filterTabs = document.querySelectorAll('.filter-tab');

  if (filterSections.length > 0 && filterTabs.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const key = entry.target.dataset.filterSection;
            filterTabs.forEach((tab) => {
              tab.classList.toggle('is-active', tab.dataset.filterKey === key);
            });
          }
        }
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 },
    );

    filterSections.forEach((section) => observer.observe(section));
  }
</script>
